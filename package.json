  "homepage": "https://github.com/bughela/tonsh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bughela/tonsh.git"
  },
  "bugs": {
    "url": "https://github.com/bughela/tonsh/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",

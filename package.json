  "bin": {
    "tonsh": "./bin/tonsh.js"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "start": "node bin/tonsh.js",
